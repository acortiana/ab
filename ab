#!/usr/bin/env bash
#
# ab - CLI for disposable Docker containers (shell, testing, prototyping).
#
# Thin wrapper around `docker`. Philosophy: KISS, single file, no dependencies
# beyond `docker` and the standard tools available on any Linux system.
#
# MAINTAINER CONVENTION:
#   All calls to external commands ALWAYS use the long form of options where
#   available (--detach instead of -d, --volume instead of -v, --interactive
#   --tty instead of -it, etc). This keeps the code self-explanatory even for
#   those who don't know every flag by heart.
#
# Operating model (git-like):
#   - create an empty directory and initialize it with `ab init`;
#   - subsequent commands are run from inside that directory;
#   - an initialized directory is recognized by the .env file with AB_PROJECT=true.
#
set -euo pipefail

# --- configurable defaults -------------------------------------------------
DEFAULT_IMAGE="ubuntu:22.04"
DEFAULT_USER="myuser"
DEFAULT_GROUP="mygroup"
DEFAULT_CMD="sleep infinity"

# ==========================================================================
# Helpers
# ==========================================================================

# Print an error message to stderr and exit with status 1.
die() {
    printf 'Error: %s\n' "$*" >&2
    exit 1
}

# Print a (non-fatal) warning to stderr.
warn() {
    printf 'Warning: %s\n' "$*" >&2
}

# Show CLI usage.
usage() {
    cat <<'EOF'
Usage: ab <command>

Commands:
  init      Initialize the current directory (interactive only)
  create    Create and start the container
  destroy   Destroy the container (does NOT touch host data)
  shell     Open an interactive shell as an unprivileged user
  root      Open an interactive shell as root
EOF
}

# Check that docker is installed and the daemon is reachable.
preflight_docker() {
    command -v docker >/dev/null 2>&1 \
        || die "the 'docker' command is not installed or not in PATH."
    docker info >/dev/null 2>&1 \
        || die "the Docker daemon is not reachable (is it running? do you have permissions?)."
}

# Check that we're in a directory initialized by `ab init`.
require_project() {
    [ -f .env ] \
        || die "this directory is not initialized: .env file is missing. Run 'ab init'."
    grep -q '^AB_PROJECT=true$' .env \
        || die "the .env file does not contain 'AB_PROJECT=true': directory not initialized."
}

# Load the .env variables, exporting them into the environment.
load_env() {
    set -a
    # shellcheck disable=SC1091
    . ./.env
    set +a
}

# Wraps a value in single quotes (escaping any internal single quotes) in a
# form that's safe to write into .env and re-source via `.`/source. E.g.:
#   sleep infinity            -> 'sleep infinity'
#   bash -c "echo hello"      -> 'bash -c "echo hello"'
shell_quote() {
    local s=$1
    s=${s//\'/\'\\\'\'}
    printf "'%s'" "$s"
}

# Generate 8 random lowercase alphanumeric characters from /dev/urandom.
# The subshell with `set +o pipefail` prevents the SIGPIPE sent to `tr`
# when `head` closes the pipe from making the function fail.
random_name() {
    ( set +o pipefail
      LC_ALL=C tr -dc 'a-z0-9' < /dev/urandom | head -c 8 )
}

# Show a question with a default value in [] and return the answer
# (Enter accepts the default). Usage: value=$(ask "Text" "default")
ask() {
    local answer
    read -r -p "$1 [$2]: " answer
    printf '%s' "${answer:-$2}"
}

# Yes/No question with default No. Returns 0 if the user answers yes.
# Usage: if ask_yes_no "Enable X?"; then ...
ask_yes_no() {
    local answer
    read -r -p "$1 [y/N]: " answer
    case "$answer" in
        [yY] | [yY][eE][sS]) return 0 ;;
        *)                   return 1 ;;
    esac
}

# ==========================================================================
# ab init
# ==========================================================================
cmd_init() {
    [ "$#" -eq 0 ] || die "'ab init' does not accept arguments or flags."

    # The directory must be completely empty (dotfiles included).
    if [ -n "$(ls -A .)" ]; then
        die "the current directory is not empty. 'ab init' requires a completely empty directory."
    fi

    echo "Initializing the ab project in the current directory."
    echo "Press Enter to accept the default value shown in brackets."
    echo

    local container_name base_image username groupname container_cmd enable_x11 enable_wayland
    container_name=$(ask "Container name" "$(random_name)")
    base_image=$(ask    "Base image"      "$DEFAULT_IMAGE")
    username=$(ask      "Username"        "$DEFAULT_USER")
    groupname=$(ask     "Groupname"       "$DEFAULT_GROUP")
    container_cmd=$(ask "Startup command" "$DEFAULT_CMD")

    if ask_yes_no "Enable X11 support?";     then enable_x11=true;     else enable_x11=false;     fi
    if ask_yes_no "Enable Wayland support?"; then enable_wayland=true; else enable_wayland=false; fi

    # Persistent subdirectories on the host.
    mkdir --parents home bin

    # .env file actually read at runtime, with a comment for each key.
    cat > .env <<EOF
# Configuration file for the ab project. Editable by hand.
# Full reference of the options: see .env.example

# Marker for an initialized project. DO NOT remove.
AB_PROJECT=true

# Name of the Docker container.
CONTAINER_NAME=$(shell_quote "$container_name")

# Base image used for the container.
BASE_IMAGE=$(shell_quote "$base_image")

# Name of the unprivileged user created in the container.
USERNAME=$(shell_quote "$username")

# Name of the user's primary group in the container.
GROUPNAME=$(shell_quote "$groupname")

# Main command run at container startup.
CONTAINER_CMD=$(shell_quote "$container_cmd")

# X11 graphical support (true|false).
ENABLE_X11=$enable_x11

# Wayland graphical support (true|false).
ENABLE_WAYLAND=$enable_wayland
EOF

    # Full documentation reference file. Never read by ab at runtime.
    cat > .env.example <<'EOF'
# .env.example - full reference of the ab project options.
# This file is documentation only: ab reads exclusively the .env file.
# Copy/paste the keys you want to change into your .env.

# AB_PROJECT
#   Marker for an initialized directory. Must be exactly "true",
#   otherwise ab refuses any command other than 'init'.
#   Value: true
AB_PROJECT=true

# CONTAINER_NAME
#   Name of the Docker container created by 'ab create'.
#   Default: 8 random alphanumeric characters generated by 'ab init'.
CONTAINER_NAME=example12

# BASE_IMAGE
#   Base Docker image. Any tag valid for 'docker run'.
#   Default: ubuntu:22.04
BASE_IMAGE=ubuntu:22.04

# USERNAME
#   Name of the unprivileged user created in the container. If the image
#   already has a user/group with the same name or the same UID/GID as the
#   host, it is removed and recreated with the correct values.
#   Default: myuser
USERNAME=myuser

# GROUPNAME
#   Name of the user's primary group in the container.
#   Default: mygroup
GROUPNAME=mygroup

# CONTAINER_CMD
#   Main command of the container (PID 1). Wrap it in single quotes if it
#   contains spaces or special characters (e.g. quotes).
#   Default: 'sleep infinity'
CONTAINER_CMD='sleep infinity'

# ENABLE_X11
#   Enable X11 graphical forwarding to the host.
#   Allowed values: true | false   (Default: false)
ENABLE_X11=false

# ENABLE_WAYLAND
#   Enable Wayland graphical forwarding to the host.
#   Allowed values: true | false   (Default: false)
ENABLE_WAYLAND=false
EOF

    echo
    echo "Project initialized:"
    echo "  - container: $container_name"
    echo "  - image:     $base_image"
    echo "  - directory: home/ bin/ .env .env.example"
    echo
    echo "Next step: 'ab create'."
}

# ==========================================================================
# ab create
# ==========================================================================
cmd_create() {
    # No container with this name must already exist (in any state).
    if docker ps --all --format '{{.Names}}' | grep -qx "$CONTAINER_NAME"; then
        die "a container named '$CONTAINER_NAME' already exists. Run 'ab destroy' before recreating it."
    fi

    local host_uid host_gid
    host_uid=$(id -u)
    host_gid=$(id -g)

    if [ "$host_uid" -eq 0 ]; then
        die "ab must not be run as root on the host: UID 0 would conflict with the container's root user. Run ab as an unprivileged user."
    fi

    # The user's home is always /home/$USERNAME (the user is the one chosen
    # in .env, not the image's default): no preliminary inspection is needed.
    local effective_home="/home/$USERNAME"

    # Build the 'docker run' arguments (long form).
    local run_args=(
        --detach
        --name "$CONTAINER_NAME"
        --volume "$PWD/home:$effective_home"
        --volume "$PWD/bin:/usr/local/bin"
    )

    # Optional graphical flags.
    if [ "${ENABLE_X11:-false}" = "true" ]; then
        [ -n "${DISPLAY:-}" ] || warn "ENABLE_X11=true but \$DISPLAY is not set."
        local xauth="${XAUTHORITY:-$HOME/.Xauthority}"
        [ -e "$xauth" ] || warn "Xauthority file '$xauth' does not exist: the mount might fail."
        run_args+=(
            --volume /tmp/.X11-unix:/tmp/.X11-unix
            --env "DISPLAY=${DISPLAY:-}"
            --volume "$xauth:$effective_home/.Xauthority:ro"
            --env "XAUTHORITY=$effective_home/.Xauthority"
        )
    fi
    if [ "${ENABLE_WAYLAND:-false}" = "true" ]; then
        [ -n "${XDG_RUNTIME_DIR:-}" ] || warn "ENABLE_WAYLAND=true but \$XDG_RUNTIME_DIR is not set."
        run_args+=(
            --volume "$XDG_RUNTIME_DIR/wayland-0:/run/user/$host_uid/wayland-0"
            --env "WAYLAND_DISPLAY=wayland-0"
            --env "XDG_RUNTIME_DIR=/run/user/$host_uid"
        )
    fi

    # Start the container. $CONTAINER_CMD intentionally NOT quoted so it
    # splits into arguments (e.g. "sleep infinity" -> two arguments).
    echo "Starting container '$CONTAINER_NAME'..."
    docker run "${run_args[@]}" "$BASE_IMAGE" $CONTAINER_CMD >/dev/null

    # User/group provisioning by editing /etc/passwd and /etc/group directly:
    # a single portable code path on any distro (Alpine included), with no
    # dependency on useradd/adduser/shadow. Host values are passed via --env
    # to avoid quoting issues.
    #
    # Strategy: ALWAYS use the user/group chosen in .env. If a pre-existing
    # user or group overlaps the chosen name or the host UID/GID, the
    # conflicting line is removed and recreated with the correct values.
    echo "Provisioning user '$USERNAME' (UID $host_uid) and group '$GROUPNAME' (GID $host_gid)..."
    docker exec --user root \
        --env USERNAME="$USERNAME" \
        --env GROUPNAME="$GROUPNAME" \
        --env HOST_UID="$host_uid" \
        --env HOST_GID="$host_gid" \
        "$CONTAINER_NAME" sh -c '
            set -e

            # Group: remove conflicting lines (same name or same GID),
            # then create the chosen group.
            sed -i "/^${GROUPNAME}:/d" /etc/group
            sed -i "/^[^:]*:[^:]*:${HOST_GID}:/d" /etc/group
            echo "${GROUPNAME}:x:${HOST_GID}:" >> /etc/group

            # Login shell: bash if present in the image, otherwise /bin/sh.
            if command -v bash >/dev/null 2>&1; then
                LOGIN_SHELL=$(command -v bash)
            else
                LOGIN_SHELL=/bin/sh
            fi

            # User: remove conflicting lines (same name or same UID),
            # then create the chosen user with home and shell.
            sed -i "/^${USERNAME}:/d" /etc/passwd
            sed -i "/^[^:]*:[^:]*:${HOST_UID}:/d" /etc/passwd
            echo "${USERNAME}:x:${HOST_UID}:${HOST_GID}::/home/${USERNAME}:${LOGIN_SHELL}" >> /etc/passwd

            mkdir -p "/home/${USERNAME}"
        '

    echo "Container '$CONTAINER_NAME' ready. Use 'ab shell' or 'ab root'."
}

# ==========================================================================
# ab destroy
# ==========================================================================
cmd_destroy() {
    if ! docker ps --all --format '{{.Names}}' | grep -qx "$CONTAINER_NAME"; then
        die "container '$CONTAINER_NAME' does not exist."
    fi
    # Never touches home/, bin/, .env, .env.example or the host directory.
    docker rm --force "$CONTAINER_NAME" >/dev/null
    echo "Container '$CONTAINER_NAME' destroyed. Host data (home/, bin/) is intact."
}

# ==========================================================================
# ab shell / ab root
# ==========================================================================

# Returns the container's state: "running", "exited"/"created"/..., or an
# empty string if it doesn't exist.
container_state() {
    docker inspect --format '{{.State.Status}}' "$CONTAINER_NAME" 2>/dev/null || true
}

# Starts the container if it's stopped; exits with an error if it doesn't exist.
ensure_running() {
    local state
    state=$(container_state)
    [ -n "$state" ] \
        || die "container '$CONTAINER_NAME' does not exist. Run 'ab create'."
    if [ "$state" != "running" ]; then
        echo "The container was stopped: restarting it..."
        docker start "$CONTAINER_NAME" >/dev/null
    fi
}

cmd_shell() {
    ensure_running
    local home shell
    home="/home/$USERNAME"
    # Login shell (field 7) of the chosen user: no hardcoded bash, so this
    # also works where bash isn't available (fallback /bin/sh).
    shell=$(docker exec "$CONTAINER_NAME" \
        awk -F: -v u="$USERNAME" '$1==u {print $7; exit}' /etc/passwd)
    docker exec --interactive --tty \
        --user "$USERNAME" \
        --workdir "$home" \
        --env HOME="$home" \
        "$CONTAINER_NAME" "${shell:-/bin/sh}"
}

cmd_root() {
    ensure_running
    local rhome rshell
    read -r rhome rshell < <(docker exec "$CONTAINER_NAME" \
        awk -F: '$3==0 {print $6, $7; exit}' /etc/passwd)
    docker exec --interactive --tty \
        --user root \
        --workdir "${rhome:-/root}" \
        --env HOME="${rhome:-/root}" \
        "$CONTAINER_NAME" "${rshell:-/bin/sh}"
}

# ==========================================================================
# Dispatch
# ==========================================================================
main() {
    case "${1:-}" in
        init)
            shift
            cmd_init "$@"
            ;;
        create)
            preflight_docker; require_project; load_env; cmd_create
            ;;
        destroy)
            preflight_docker; require_project; load_env; cmd_destroy
            ;;
        shell)
            preflight_docker; require_project; load_env; cmd_shell
            ;;
        root)
            preflight_docker; require_project; load_env; cmd_root
            ;;
        "" | -h | --help | help)
            usage
            ;;
        *)
            usage
            exit 1
            ;;
    esac
}

main "$@"
