#!/usr/bin/env bash
#
# ab - CLI for disposable Docker containers (shell, testing, prototyping).
#
# Thin wrapper around `docker`. Philosophy: KISS, single file, no dependencies
# beyond `docker` and the standard tools available on any Linux system.
#
# MAINTAINER CONVENTION:
#   All calls to external commands ALWAYS use the long form of options where
#   available (--detach instead of -d, --volume instead of -v, --interactive
#   --tty instead of -it, etc). This keeps the code self-explanatory even for
#   those who don't know every flag by heart.
#
# Operating model (git-like):
#   - create an empty directory and initialize it with `ab init`;
#   - subsequent commands are run from inside that directory;
#   - an initialized directory is recognized by the .env file with AB_PROJECT=true.
#
set -euo pipefail

# --- configurable defaults -------------------------------------------------
DEFAULT_IMAGE="ubuntu:22.04"
DEFAULT_USER="myuser"
DEFAULT_GROUP="mygroup"
DEFAULT_CMD="sleep infinity"

# ==========================================================================
# Helpers
# ==========================================================================

# Print an error message to stderr and exit with status 1.
die() {
    printf 'Error: %s\n' "$*" >&2
    exit 1
}

# Print a (non-fatal) warning to stderr.
warn() {
    printf 'Warning: %s\n' "$*" >&2
}

# Show CLI usage.
usage() {
    cat <<'EOF'
Usage: ab <command>

Commands:
  init      Initialize the current directory (interactive only)
  create    Create and start the container
  destroy   Destroy the container (does NOT touch host data)
  shell     Open an interactive shell as an unprivileged user
  root      Open an interactive shell as root
EOF
}

# Check that docker is installed and the daemon is reachable.
preflight_docker() {
    command -v docker >/dev/null 2>&1 \
        || die "the 'docker' command is not installed or not in PATH."
    docker info >/dev/null 2>&1 \
        || die "the Docker daemon is not reachable (is it running? do you have permissions?)."
}

# Check that we're in a directory initialized by `ab init`.
require_project() {
    [ -f .env ] \
        || die "this directory is not initialized: .env file is missing. Run 'ab init'."
    grep -q '^AB_PROJECT=true$' .env \
        || die "the .env file does not contain 'AB_PROJECT=true': directory not initialized."
}

# Load the .env variables, exporting them into the environment.
load_env() {
    set -a
    # shellcheck disable=SC1091
    . ./.env
    set +a
}

# Wraps a value in single quotes (escaping any internal single quotes) in a
# form that's safe to write into .env and re-source via `.`/source. E.g.:
#   sleep infinity            -> 'sleep infinity'
#   bash -c "echo hello"      -> 'bash -c "echo hello"'
shell_quote() {
    local s=$1
    s=${s//\'/\'\\\'\'}
    printf "'%s'" "$s"
}

# Generate 8 random lowercase alphanumeric characters from /dev/urandom.
# The subshell with `set +o pipefail` prevents the SIGPIPE sent to `tr`
# when `head` closes the pipe from making the function fail.
random_name() {
    ( set +o pipefail
      LC_ALL=C tr -dc 'a-z0-9' < /dev/urandom | head -c 8 )
}

# Show a question with a default value in [] and return the answer
# (Enter accepts the default). Usage: value=$(ask "Text" "default")
ask() {
    local answer
    read -r -p "$1 [$2]: " answer
    printf '%s' "${answer:-$2}"
}

# Yes/No question with default No. Returns 0 if the user answers yes.
# Usage: if ask_yes_no "Enable X?"; then ...
ask_yes_no() {
    local answer
    read -r -p "$1 [y/N]: " answer
    case "$answer" in
        [yY] | [yY][eE][sS]) return 0 ;;
        *)                   return 1 ;;
    esac
}

# Run the active scripts found in host directory $1, in alphabetical order,
# inside $CONTAINER_NAME with working directory $2, via "docker exec
# --interactive --tty" using the extra arguments $4 $5 ... (e.g. "--user
# root" or "--user $USERNAME --env HOME=$home"). $3 is a short label used in
# messages (e.g. "provisioning script", "startup script"). Runs in the
# foreground, attached to the same terminal: scripts needing user
# interaction behave as if the commands were typed directly.
#
# Active scripts follow the run-parts naming convention: filenames made up
# only of [A-Za-z0-9_-] (no dots) -- any other name (README.md, *.disabled,
# *.bak, ...) is skipped, which doubles as the "disable via rename"
# mechanism. If the host directory doesn't exist, the glob below stays
# unexpanded, "-f" is false, and the loop is a silent no-op.
#
# Stops and warns at the first script that is not executable or exits with
# an error, then returns non-zero: the caller decides whether that's fatal
# (provision.d/ -> die) or not (startup.d/ -> report and carry on).
run_scripts_dir() {
    local host_dir=$1 container_workdir=$2 label=$3
    shift 3
    local rel=${host_dir#"$PWD/"}
    local script name
    for script in "$host_dir"/*; do
        [ -f "$script" ] || continue
        name=$(basename "$script")
        case "$name" in
            *[!A-Za-z0-9_-]*) continue ;;
        esac
        if [ ! -x "$script" ]; then
            warn "$label '$rel/$name' is not executable. Run 'chmod +x $rel/$name', or rename it (e.g. add '.disabled') to skip it."
            return 1
        fi
        echo "Running $label '$name'..."
        docker exec --interactive --tty "$@" --workdir "$container_workdir" \
            "$CONTAINER_NAME" "$container_workdir/$name" \
            || { warn "$label '$name' exited with an error."; return 1; }
    done
}

# ==========================================================================
# ab init
# ==========================================================================
cmd_init() {
    [ "$#" -eq 0 ] || die "'ab init' does not accept arguments or flags."

    # The directory must be completely empty (dotfiles included).
    if [ -n "$(ls -A .)" ]; then
        die "the current directory is not empty. 'ab init' requires a completely empty directory."
    fi

    echo "Initializing the ab project in the current directory."
    echo "Press Enter to accept the default value shown in brackets."
    echo

    local container_name base_image username groupname container_cmd enable_x11 enable_wayland
    container_name=$(ask "Container name" "$(random_name)")
    base_image=$(ask    "Base image"      "$DEFAULT_IMAGE")
    username=$(ask      "Username"        "$DEFAULT_USER")
    groupname=$(ask     "Groupname"       "$DEFAULT_GROUP")
    container_cmd=$(ask "Startup command" "$DEFAULT_CMD")

    if ask_yes_no "Enable X11 support?";     then enable_x11=true;     else enable_x11=false;     fi
    if ask_yes_no "Enable Wayland support?"; then enable_wayland=true; else enable_wayland=false; fi

    # Persistent subdirectories on the host.
    mkdir --parents home bin provision.d home/startup.d

    # .env file actually read at runtime, with a comment for each key.
    cat > .env <<EOF
# Configuration file for the ab project. Editable by hand.
# Full reference of the options: see .env.example

# Marker for an initialized project. DO NOT remove.
AB_PROJECT=true

# Name of the Docker container.
CONTAINER_NAME=$(shell_quote "$container_name")

# Base image used for the container.
BASE_IMAGE=$(shell_quote "$base_image")

# Name of the unprivileged user created in the container.
USERNAME=$(shell_quote "$username")

# Name of the user's primary group in the container.
GROUPNAME=$(shell_quote "$groupname")

# Main command run at container startup.
CONTAINER_CMD=$(shell_quote "$container_cmd")

# X11 graphical support (true|false).
ENABLE_X11=$enable_x11

# Wayland graphical support (true|false).
ENABLE_WAYLAND=$enable_wayland
EOF

    # Full documentation reference file. Never read by ab at runtime.
    cat > .env.example <<'EOF'
# .env.example - full reference of the ab project options.
# This file is documentation only: ab reads exclusively the .env file.
# Copy/paste the keys you want to change into your .env.

# AB_PROJECT
#   Marker for an initialized directory. Must be exactly "true",
#   otherwise ab refuses any command other than 'init'.
#   Value: true
AB_PROJECT=true

# CONTAINER_NAME
#   Name of the Docker container created by 'ab create'.
#   Default: 8 random alphanumeric characters generated by 'ab init'.
CONTAINER_NAME=example12

# BASE_IMAGE
#   Base Docker image. Any tag valid for 'docker run'.
#   Default: ubuntu:22.04
BASE_IMAGE=ubuntu:22.04

# USERNAME
#   Name of the unprivileged user created in the container. If the image
#   already has a user/group with the same name or the same UID/GID as the
#   host, it is removed and recreated with the correct values.
#   Default: myuser
USERNAME=myuser

# GROUPNAME
#   Name of the user's primary group in the container.
#   Default: mygroup
GROUPNAME=mygroup

# CONTAINER_CMD
#   Main command of the container (PID 1). Wrap it in single quotes if it
#   contains spaces or special characters (e.g. quotes).
#   Default: 'sleep infinity'
CONTAINER_CMD='sleep infinity'

# ENABLE_X11
#   Enable X11 graphical forwarding to the host.
#   Allowed values: true | false   (Default: false)
ENABLE_X11=false

# ENABLE_WAYLAND
#   Enable Wayland graphical forwarding to the host.
#   Allowed values: true | false   (Default: false)
ENABLE_WAYLAND=false
EOF

    # README for provision.d/ (documentation only, never read by ab).
    cat > provision.d/README.md <<'EOF'
# provision.d/

Scripts placed in this directory are executed **as root**, **in alphabetical
order**, right after the container is created by `ab create` (before the
command returns). They run in the foreground, attached to the same terminal:
scripts that need user interaction behave exactly as if you typed the
commands yourself.

## Naming convention

- Active scripts: filenames made up **only** of letters, digits, `_` and `-`
  (e.g. `10-install-packages`, `20-clone-repo`). The leading number sets the
  execution order; leave gaps (10, 20, 30, ...) to make room for future
  insertions.
- To temporarily disable a script **without deleting it**, rename it adding
  any suffix that contains a dot (e.g. `10-install-packages.disabled`,
  `.bak`, `.off`, ...): any filename containing a dot is skipped. This is
  also why this README, and any other documentation placed here, is never
  executed.
- Each script must be executable (`chmod +x scriptname`) and start with a
  shebang line (`#!/bin/sh`, `#!/usr/bin/env bash`, ...). The interpreter
  must be available in the container image.

## Rules

- Scripts run **as root**, in the order given by their name.
- Each script **must** end with `exit 0`. If any script exits with a
  non-zero status, `ab create` stops immediately, reports an error, and
  leaves the container running so you can inspect what happened (`ab root`
  / `ab shell`). Destroy it with `ab destroy` before retrying `ab create`.

## Example

See `00-example.disabled` for a minimal working script, shipped already
disabled so that a freshly initialized project doesn't run anything by
default. To try it out:

    mv 00-example.disabled 00-example
    ab create
EOF

    # Example script: shipped disabled (the ".disabled" suffix contains a
    # dot, so the naming convention above skips it) and already executable,
    # so enabling it is a matter of a simple rename.
    cat > provision.d/00-example.disabled <<'EOF'
#!/bin/sh
#
# Example provisioning script: runs as root right after container creation.
#
# To activate it, rename this file removing the ".disabled" suffix (it's
# already executable). To deactivate it again, rename it back, or add any
# other suffix containing a dot. See README.md in this directory for the
# full naming convention.

set -e

echo "Hello from provision.d/00-example!"
echo "Running as: $(id -un) (uid=$(id -u))"

# Add your provisioning commands here: install packages, clone repositories,
# write configuration files, create system users, etc. Remember: this script
# MUST end with "exit 0", otherwise 'ab create' will report an error.

exit 0
EOF
    chmod +x provision.d/00-example.disabled

    # README for home/startup.d/ (documentation only, never read by ab).
    cat > home/startup.d/README.md <<'EOF'
# startup.d/

Scripts placed in this directory are executed **as the unprivileged user**
(`$USERNAME`), **in alphabetical order**, every time `ab` (re)starts the
container -- both on the very first `ab create` (right after `provision.d/`)
and on every later restart triggered by `ab shell`/`ab root` finding it
stopped. They run in the foreground, attached to the same terminal.

Use this directory for things that need to happen on every boot: starting a
background service, syncing dotfiles, regenerating configuration that
depends on the host, and so on. For one-shot setup that should run only once
(installing packages, cloning repositories, ...), use `provision.d/` instead.

This directory is **not mandatory**: if you delete it, `ab` simply skips it.

## Important differences from provision.d/

- **Runs as your unprivileged user, not root.** This directory lives inside
  your `home/`, which you own: running arbitrary content from here as root
  would turn any file that lands in it into a potential root-execution
  vector. If you need root, use `provision.d/`.
- **Scripts must be idempotent.** Unlike `provision.d/` (which runs once),
  these scripts can run many times over the life of the same container:
  write them so that running them again causes no harm.
- **A failing script never blocks `ab`.** `ab` reports the problem with a
  warning and carries on (it would be unhelpful to lock you out of your own
  container just because a startup script misbehaved). Still, end your
  scripts with `exit 0` on success: it documents your intent and makes
  failures easy to spot in the warning.
- **Coverage is limited to restarts mediated by `ab`.** `ab` cannot intercept
  a container started in some other way (e.g. a direct `docker start`, or a
  Docker restart policy): scripts here run only when `ab create`/`ab
  shell`/`ab root` is what (re)starts the container.

## Naming convention

Same run-parts style as `provision.d/`: active scripts have names made up
**only** of letters, digits, `_` and `-` (e.g. `10-start-service`,
`20-sync-dotfiles`); to disable one temporarily, rename it adding any suffix
that contains a dot (e.g. `10-start-service.disabled`). See the README in
`provision.d/` for the full rationale -- it applies here unchanged.

## Example

See `00-example.disabled` for a minimal working script, shipped already
disabled so that a freshly initialized project doesn't run anything by
default. To try it out:

    mv 00-example.disabled 00-example
    ab create
EOF

    # Example script: shipped disabled and already executable, so enabling
    # it is a matter of a simple rename (see provision.d/00-example.disabled
    # for the rationale of this convention).
    cat > home/startup.d/00-example.disabled <<'EOF'
#!/bin/sh
#
# Example startup script: runs as your unprivileged user every time `ab`
# (re)starts the container.
#
# To activate it, rename this file removing the ".disabled" suffix (it's
# already executable). To deactivate it again, rename it back, or add any
# other suffix containing a dot. See README.md in this directory for the
# full naming convention -- and remember: unlike provision.d/, this script
# may run many times, so it must be idempotent.

set -e

echo "Hello from startup.d/00-example!"
echo "Running as: $(id -un) (uid=$(id -u))"

# Add your startup commands here: start a background service, sync
# dotfiles, regenerate configuration, etc. Keep it idempotent: running it
# again (on the next restart) must cause no harm. A failing script only
# produces a warning -- it never blocks 'ab' -- but ending with "exit 0"
# documents that everything went as expected.

exit 0
EOF
    chmod +x home/startup.d/00-example.disabled

    echo
    echo "Project initialized:"
    echo "  - container: $container_name"
    echo "  - image:     $base_image"
    echo "  - directory: home/ (with startup.d/) bin/ provision.d/ .env .env.example"
    echo
    echo "Next step: 'ab create'."
}

# ==========================================================================
# ab create
# ==========================================================================
cmd_create() {
    # No container with this name must already exist (in any state).
    if docker ps --all --format '{{.Names}}' | grep -qx "$CONTAINER_NAME"; then
        die "a container named '$CONTAINER_NAME' already exists. Run 'ab destroy' before recreating it."
    fi

    [ -d provision.d ] \
        || die "the 'provision.d' directory is missing (it should have been created by 'ab init'): this project looks corrupted."

    local host_uid host_gid
    host_uid=$(id -u)
    host_gid=$(id -g)

    if [ "$host_uid" -eq 0 ]; then
        die "ab must not be run as root on the host: UID 0 would conflict with the container's root user. Run ab as an unprivileged user."
    fi

    # The user's home is always /home/$USERNAME (the user is the one chosen
    # in .env, not the image's default): no preliminary inspection is needed.
    local effective_home="/home/$USERNAME"

    # Build the 'docker run' arguments (long form).
    local run_args=(
        --detach
        --name "$CONTAINER_NAME"
        --volume "$PWD/home:$effective_home"
        --volume "$PWD/bin:/usr/local/bin"
        --volume "$PWD/provision.d:/usr/local/provision.d"
    )

    # Optional graphical flags.
    if [ "${ENABLE_X11:-false}" = "true" ]; then
        [ -n "${DISPLAY:-}" ] || warn "ENABLE_X11=true but \$DISPLAY is not set."
        local xauth="${XAUTHORITY:-$HOME/.Xauthority}"
        [ -e "$xauth" ] || warn "Xauthority file '$xauth' does not exist: the mount might fail."
        run_args+=(
            --volume /tmp/.X11-unix:/tmp/.X11-unix
            --env "DISPLAY=${DISPLAY:-}"
            --volume "$xauth:$effective_home/.Xauthority:ro"
            --env "XAUTHORITY=$effective_home/.Xauthority"
        )
    fi
    if [ "${ENABLE_WAYLAND:-false}" = "true" ]; then
        [ -n "${XDG_RUNTIME_DIR:-}" ] || warn "ENABLE_WAYLAND=true but \$XDG_RUNTIME_DIR is not set."
        run_args+=(
            --volume "$XDG_RUNTIME_DIR/wayland-0:/run/user/$host_uid/wayland-0"
            --env "WAYLAND_DISPLAY=wayland-0"
            --env "XDG_RUNTIME_DIR=/run/user/$host_uid"
        )
    fi

    # Start the container. $CONTAINER_CMD intentionally NOT quoted so it
    # splits into arguments (e.g. "sleep infinity" -> two arguments).
    echo "Starting container '$CONTAINER_NAME'..."
    docker run "${run_args[@]}" "$BASE_IMAGE" $CONTAINER_CMD >/dev/null

    # User/group provisioning by editing /etc/passwd and /etc/group directly:
    # a single portable code path on any distro (Alpine included), with no
    # dependency on useradd/adduser/shadow. Host values are passed via --env
    # to avoid quoting issues.
    #
    # Strategy: ALWAYS use the user/group chosen in .env. If a pre-existing
    # user or group overlaps the chosen name or the host UID/GID, the
    # conflicting line is removed and recreated with the correct values.
    echo "Provisioning user '$USERNAME' (UID $host_uid) and group '$GROUPNAME' (GID $host_gid)..."
    docker exec --user root \
        --env USERNAME="$USERNAME" \
        --env GROUPNAME="$GROUPNAME" \
        --env HOST_UID="$host_uid" \
        --env HOST_GID="$host_gid" \
        "$CONTAINER_NAME" sh -c '
            set -e

            # Group: remove conflicting lines (same name or same GID),
            # then create the chosen group.
            sed -i "/^${GROUPNAME}:/d" /etc/group
            sed -i "/^[^:]*:[^:]*:${HOST_GID}:/d" /etc/group
            echo "${GROUPNAME}:x:${HOST_GID}:" >> /etc/group

            # Login shell: bash if present in the image, otherwise /bin/sh.
            if command -v bash >/dev/null 2>&1; then
                LOGIN_SHELL=$(command -v bash)
            else
                LOGIN_SHELL=/bin/sh
            fi

            # User: remove conflicting lines (same name or same UID),
            # then create the chosen user with home and shell.
            sed -i "/^${USERNAME}:/d" /etc/passwd
            sed -i "/^[^:]*:[^:]*:${HOST_UID}:/d" /etc/passwd
            echo "${USERNAME}:x:${HOST_UID}:${HOST_GID}::/home/${USERNAME}:${LOGIN_SHELL}" >> /etc/passwd

            mkdir -p "/home/${USERNAME}"
        '

    # Run provisioning scripts from provision.d/ as root (see run_scripts_dir
    # for the naming convention and the "disable via rename" mechanism).
    # Every script must end with "exit 0": on the first failure, 'ab create'
    # stops and leaves the container running for inspection.
    run_scripts_dir "$PWD/provision.d" "/usr/local/provision.d" "provisioning script" --user root \
        || die "container '$CONTAINER_NAME' left running for inspection ('ab root' / 'ab shell'). Destroy it with 'ab destroy' before retrying 'ab create'."

    # Run startup scripts from home/startup.d/ (if present), as the
    # unprivileged user -- including on this very first start, right after
    # provisioning. Unlike provision.d/, this directory is optional and a
    # failure here never blocks 'ab create': run_scripts_dir already reports
    # the problem via a warning, so 'ab create' simply carries on.
    run_scripts_dir "$PWD/home/startup.d" "$effective_home/startup.d" "startup script" \
        --user "$USERNAME" --env "HOME=$effective_home" || true

    echo "Container '$CONTAINER_NAME' ready. Use 'ab shell' or 'ab root'."
}

# ==========================================================================
# ab destroy
# ==========================================================================
cmd_destroy() {
    if ! docker ps --all --format '{{.Names}}' | grep -qx "$CONTAINER_NAME"; then
        die "container '$CONTAINER_NAME' does not exist."
    fi
    # Never touches home/, bin/, provision.d/, .env, .env.example or the host directory.
    docker rm --force "$CONTAINER_NAME" >/dev/null
    echo "Container '$CONTAINER_NAME' destroyed. Host data (home/, bin/, provision.d/) is intact."
}

# ==========================================================================
# ab shell / ab root
# ==========================================================================

# Returns the container's state: "running", "exited"/"created"/..., or an
# empty string if it doesn't exist.
container_state() {
    docker inspect --format '{{.State.Status}}' "$CONTAINER_NAME" 2>/dev/null || true
}

# Starts the container if it's stopped; exits with an error if it doesn't exist.
ensure_running() {
    local state
    state=$(container_state)
    [ -n "$state" ] \
        || die "container '$CONTAINER_NAME' does not exist. Run 'ab create'."
    if [ "$state" != "running" ]; then
        echo "The container was stopped: restarting it..."
        docker start "$CONTAINER_NAME" >/dev/null

        # Run startup scripts from home/startup.d/ (if present), as the
        # unprivileged user, now that the container is actually (re)starting
        # -- never when it was already running. See run_scripts_dir for the
        # naming convention; a failure here only produces a warning.
        local home="/home/$USERNAME"
        run_scripts_dir "$PWD/home/startup.d" "$home/startup.d" "startup script" \
            --user "$USERNAME" --env "HOME=$home" || true
    fi
}

cmd_shell() {
    ensure_running
    local home shell
    home="/home/$USERNAME"
    # Login shell (field 7) of the chosen user: no hardcoded bash, so this
    # also works where bash isn't available (fallback /bin/sh).
    shell=$(docker exec "$CONTAINER_NAME" \
        awk -F: -v u="$USERNAME" '$1==u {print $7; exit}' /etc/passwd)
    docker exec --interactive --tty \
        --user "$USERNAME" \
        --workdir "$home" \
        --env HOME="$home" \
        "$CONTAINER_NAME" "${shell:-/bin/sh}"
}

cmd_root() {
    ensure_running
    local rhome rshell
    read -r rhome rshell < <(docker exec "$CONTAINER_NAME" \
        awk -F: '$3==0 {print $6, $7; exit}' /etc/passwd)
    docker exec --interactive --tty \
        --user root \
        --workdir "${rhome:-/root}" \
        --env HOME="${rhome:-/root}" \
        "$CONTAINER_NAME" "${rshell:-/bin/sh}"
}

# ==========================================================================
# Dispatch
# ==========================================================================
main() {
    case "${1:-}" in
        init)
            shift
            cmd_init "$@"
            ;;
        create)
            preflight_docker; require_project; load_env; cmd_create
            ;;
        destroy)
            preflight_docker; require_project; load_env; cmd_destroy
            ;;
        shell)
            preflight_docker; require_project; load_env; cmd_shell
            ;;
        root)
            preflight_docker; require_project; load_env; cmd_root
            ;;
        "" | -h | --help | help)
            usage
            ;;
        *)
            usage
            exit 1
            ;;
    esac
}

main "$@"
